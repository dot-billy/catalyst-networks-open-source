# Production Environment Variables
# Copy this file to .env.prod and fill in all values before deploying.
# NEVER commit .env.prod to version control.

# Django Settings (REQUIRED)
DJANGO_SECRET_KEY=
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_ALLOWED_HOSTS=
DJANGO_DEBUG=False
STATIC_ASSET_VERSION=
DJANGO_STATIC_ROOT=/tmp/catalyst-staticfiles
DJANGO_GENERATED_STATIC_DIR=/tmp/catalyst-generated-static
RUN_BUILD_STATIC=true
RUN_COLLECTSTATIC=true

# Human Account Registration
# Public registration stays disabled for internet-facing deployments.
# Temporarily enable bootstrap registration only during a controlled first-run window,
# or leave it disabled and seed a superuser with the settings below.
ALLOW_BOOTSTRAP_REGISTRATION=False
ALLOW_PUBLIC_REGISTRATION=False
# Optional non-interactive first admin seeding. Prefer injecting these through
# your platform secret store instead of committing them to an env file.
# CREATE_SUPERUSER=true
# DJANGO_SUPERUSER_EMAIL=
# DJANGO_SUPERUSER_PASSWORD=

# Database Settings (REQUIRED)
# Use DATABASE_URL for managed databases, or set the individual POSTGRES_* values.
# DATABASE_URL=postgres://user:password@db-host:5432/open_cvpn
POSTGRES_DB=open_cvpn
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=db

# JWT Settings
JWT_SECRET_KEY=
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"

# Field Encryption Settings (REQUIRED for notification integration secrets)
FIELD_ENCRYPTION_KEY=
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Node Registration (REQUIRED)
REGISTRATION_MASTER_TOKEN=
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# Certificate Settings
CERTIFICATE_RENEWAL_WINDOW_DAYS=14
CERTIFICATE_RENEWAL_BATCH_SIZE=10
CERTIFICATE_EXPIRY_NOTIFICATION_DAYS=30
CERT_FILE_RETENTION_DAYS=30

# Email Settings (optional)
# Verify this sender domain in Resend before enabling RESEND_API_KEY.
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
# RESEND_API_KEY=
# Optional explicit backend override for SMTP, console, or tests. Leave unset to enable Resend.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Optional Mailgun Settings
# Used only when RESEND_API_KEY and EMAIL_BACKEND are unset.
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# SSL Settings (defaults are secure, only override if needed)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# CSRF Trusted Origins (comma-separated, include scheme)
# CSRF_TRUSTED_ORIGINS=
