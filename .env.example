# Django Settings
DJANGO_SETTINGS_MODULE=open_cvpn.settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
STATIC_ASSET_VERSION=

# Database Settings
POSTGRES_DB=open_cvpn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db

# Redis Settings
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_LIFETIME=5
JWT_REFRESH_TOKEN_LIFETIME=1

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com

# Optional Mailgun Settings
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain

# Site URL Settings
BASE_URL=http://localhost:8000

# Field Encryption Settings
# Required when Slack notification integrations store webhook URLs.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Node Registration Settings
REGISTRATION_MASTER_TOKEN=master-registration-token-change-me

# Optional S3/MinIO Settings
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_ENDPOINT_URL=your-s3-endpoint

# Certificate Settings
CERTIFICATE_RENEWAL_WINDOW_DAYS=14
CERTIFICATE_RENEWAL_BATCH_SIZE=10
CERTIFICATE_EXPIRY_NOTIFICATION_DAYS=30
CERT_FILE_RETENTION_DAYS=30
