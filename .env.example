# Django Settings
DJANGO_SETTINGS_MODULE=open_cvpn.settings
DJANGO_SECRET_KEY=
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
STATIC_ASSET_VERSION=
WEB_PORT=8000
DJANGO_LOG_FILE=
DJANGO_STATIC_ROOT=/tmp/catalyst-staticfiles
DJANGO_GENERATED_STATIC_DIR=/tmp/catalyst-generated-static
RUN_BUILD_STATIC=true
RUN_COLLECTSTATIC=true

# Human Account Registration
# First installer can create the initial admin account at /register/.
# After any user exists, registration is invitation-only unless public registration is enabled.
ALLOW_BOOTSTRAP_REGISTRATION=True
ALLOW_PUBLIC_REGISTRATION=False
# Optional non-interactive first admin seeding. Leave disabled for the default
# browser bootstrap flow above.
# CREATE_SUPERUSER=true
# DJANGO_SUPERUSER_EMAIL=
# DJANGO_SUPERUSER_PASSWORD=

# Database Settings
POSTGRES_DB=open_cvpn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db

# Redis Settings
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Settings
JWT_SECRET_KEY=
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_ACCESS_TOKEN_LIFETIME=5
JWT_REFRESH_TOKEN_LIFETIME=1

# Email Settings
DEFAULT_FROM_EMAIL=noreply@example.com
# Optional Resend API email delivery. Leave EMAIL_BACKEND unset to enable this.
# RESEND_API_KEY=
# Optional explicit backend override for local console, SMTP, or tests.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Optional Mailgun Settings
# Used only when RESEND_API_KEY and EMAIL_BACKEND are unset.
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# Site URL Settings
BASE_URL=http://localhost:8000

# Field Encryption Settings
# Required when Slack notification integrations store webhook URLs.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Node Registration Settings
REGISTRATION_MASTER_TOKEN=
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# Optional S3/MinIO Settings
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=

# Certificate Settings
CERTIFICATE_RENEWAL_WINDOW_DAYS=14
CERTIFICATE_RENEWAL_BATCH_SIZE=10
CERTIFICATE_EXPIRY_NOTIFICATION_DAYS=30
CERT_FILE_RETENTION_DAYS=30
